{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@docdock/shared": ["../../packages/shared/index.ts"],
      "@docdock/shared/*": ["../../packages/shared/*"]
    },
    "noEmit": false,
    "types": ["node"]
  },
  "include": ["src/**/*"]
}
