{
  "compilerOptions": {
    "target": "ES2020",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@docdock/shared": ["packages/shared/index.ts"],
      "@docdock/shared/*": ["packages/shared/*"]
    }
  }
}

